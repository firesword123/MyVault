{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "myvault",
  "version": "0.1.0",
  "identifier": "com.facial.myvault",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "myvault",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBOTI3RDREQjI2NTI3MjYKUldRbUoyV3lUWDJTS2s0U1NYZlBNaHhZMy95WVl5WnlNZUlydXJJc3ZIMmxpcWtqWndKbkppdDEK",
      "endpoints": [
        "https://github.com/firesword123/MyVault/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
